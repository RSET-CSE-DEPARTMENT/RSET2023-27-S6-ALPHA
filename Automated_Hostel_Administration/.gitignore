# --- Dependencies (CRITICAL) ---
node_modules/
/client/node_modules
/server/node_modules
# If you use python venv in ai_engine
venv/
env/
__pycache__/
*.pyc

# --- Security (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# --- Build Outputs (Don't track compiled code) ---
dist/
build/
/client/dist
/client/build

# --- System Files ---
.DS_Store
Thumbs.db

# --- AI & Large Files (Optional but Recommended) ---
# Ignore large datasets or model weights inside ai_engine
# (GitHub rejects files larger than 100MB)
ai_engine/datasets/*.csv
ai_engine/datasets/*.json
ai_engine/models/*.h5
ai_engine/models/*.pt
ai_engine/models/*.pkl

# --- Misc ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*