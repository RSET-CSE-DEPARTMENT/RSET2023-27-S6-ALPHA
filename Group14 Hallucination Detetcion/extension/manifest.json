{
    "manifest_version": 3,
    "name": "AI Hallucination Detector",
    "version": "2.0.0",
    "description": "Detect and highlight AI-generated hallucinations on ChatGPT, Claude, and Gemini with confidence scores.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "AI Hallucination Detector"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://chat.openai.com/*",
                "https://claude.ai/*",
                "https://gemini.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "http://localhost:7890/*"
    ],
    "permissions": [
        "activeTab"
    ]
}